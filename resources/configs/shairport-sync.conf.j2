# shairport-sync configuration — generated by LX06 Flash Tool
# Reference: https://github.com/mikebrady/shairport-sync

general = {
  name = "{{ device_name | default('LX06-Speaker') }}";
  port = 5000;
  udp_port_base = 6001;
  udp_port_range = 10;
  interpolation = "basic";
  statistics = "no";
};

alsa = {
  output_device = "{{ audio_output | default('default') }}";
  mixer_control_name = "PCM";
};
